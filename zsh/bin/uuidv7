#!/usr/bin/perl

use strict;
use warnings;
use Time::HiRes qw(time);

my $timestamp = int(time() * 1000);

open my $random, '<:raw', '/dev/urandom' or die "$0: /dev/urandom: $!\n";
read($random, my $data, 10) == 10 or die "$0: failed to read random data\n";

my $hex = sprintf('%012x', $timestamp) . unpack('H*', $data);
substr($hex, 12, 1) = '7';
substr($hex, 16, 1) = sprintf '%x', (hex(substr($hex, 16, 1)) & 3) | 8;

print join('-', substr($hex, 0, 8), substr($hex, 8, 4), substr($hex, 12, 4), substr($hex, 16, 4), substr($hex, 20)), "\n";
