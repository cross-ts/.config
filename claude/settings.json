{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "0",
    "CLAUDE_CODE_ENABLE_EXPERIMENTAL_ADVISOR_TOOL": "1",
    "CLAUDE_CODE_ENABLE_AUTO_MODE": "1",
    "ENABLE_LSP_TOOL": "1"
  },
  "permissions": {
    "allow": [
      "Bash(make:*)",
      "Bash(eza:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(jq:*)",
      "Bash(difit:*)",
      "Bash(marp:*)",
      "Bash(markitdown:*)",
      "Bash(obsidian:*)",
      "Bash(duckdb:*)",
      "Bash(sqlite3:*)",
      "Bash(actionlint:*)",
      "Bash(ansible-lint:*)",
      "Bash(hadolint:*)",
      "Bash(yamllint:*)",
      "Bash(git:*)",
      "Bash(gh:*)"
    ],
    "deny": [
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(brew:*)",
      "Bash(git config:*)",
      "Bash(gh auth:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(auth.json)"
    ],
    "ask": [],
    "defaultMode": "plan"
  },
  "language": "japanese",
  "advisorModel": "opus",
  "plansDirectory": ".claude/plans",
  "autoMemoryDirectory": "~/.local/share/claude/memories",
  "theme": "auto",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "autoMode": {
    "environment": [
      "$defaults"
    ]
  }
}
