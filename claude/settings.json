{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "language": "japanese",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "0",
    "ENABLE_LSP_TOOL": "1"
  },
  "permissions": {
    "allow": [
    ],
    "ask": [
    ],
    "deny": [
      "Read(.env)",
      "Read(auth.json)",
      "Read(~/.aws/*)",
      "Read(~/.ssh/*)"
    ],
    "defaultMode": "plan"
  },
  "plansDirectory": "./plans"
}
