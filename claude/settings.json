{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "0",
    "ENABLE_LSP_TOOL": "1"
  },
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(make:*)",
      "Bash(eza:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(jq:*)",
      "Bash(difit:*)",
      "Bash(marp:*)",
      "Bash(markitdown:*)",
      "Bash(obsidian:*)",
      "Bash(duckdb:*)",
      "Bash(sqlite3:*)",
      "Bash(actionlint:*)",
      "Bash(ansible-lint:*)",
      "Bash(hadolint:*)",
      "Bash(yamllint:*)",
      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git history:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr status:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue status:*)",
      "Bash(terraform fmt:*)",
      "Bash(terraform validate:*)"
    ],
    "deny": [
      "Bash(brew install:*)",
      "Bash(brew upgrade:*)",
      "Bash(mise use:*)",
      "Bash(mise install:*)",
      "Read(.env)",
      "Read(auth.json)",
      "Read(~/.aws/*)",
      "Read(~/.ssh/*)"
    ],
    "ask": [],
    "defaultMode": "plan"
  },
  "language": "japanese",
  "plansDirectory": "./plans"
}
